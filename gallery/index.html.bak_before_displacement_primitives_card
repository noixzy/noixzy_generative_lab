<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>noixzy // generative lab</title>
<style>
  :root { --bg:#0e0e10; --panel:#1a1a1d; --ink:#e8e8ea; --accent:#ed5700; --dim:#7a7a7e; }
  html,body { margin:0; background:var(--bg); color:var(--ink);
    font:13px/1.5 ui-monospace,SFMono-Regular,Menlo,monospace; }
  header { padding:28px 28px 10px; }
  h1 { margin:0; font-size:15px; letter-spacing:.16em; text-transform:lowercase; color:var(--accent); }
  .sub { color:var(--dim); margin-top:6px; max-width:620px; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr));
    gap:14px; padding:18px 28px 40px; }
  a.card { display:block; text-decoration:none; color:var(--ink);
    background:var(--panel); border:1px solid #222; border-radius:8px; overflow:hidden; }
  a.card:hover { border-color:var(--accent); }
  .thumb { aspect-ratio:1/1; background:#000; position:relative; overflow:hidden; }
  .thumb img { width:100%; height:100%; object-fit:cover; display:block; }
  .meta { padding:11px 13px; }
  .name { color:var(--accent); text-transform:lowercase; letter-spacing:.06em; }
  .desc { color:var(--dim); margin-top:4px; font-size:12px; }
  .tag { display:inline-block; margin-top:8px; padding:2px 7px; border:1px solid #333;
    border-radius:3px; color:var(--dim); font-size:11px; }
</style>
</head>
<body>
<header>
  <h1>noixzy // generative lab</h1>
  <div class="sub">small algorithmic experiments. each is one self-contained file —
    seed on canvas, four sliders, png export. feed them into blender, music visuals,
    stills, or textures.</div>
</header>
<div class="grid" id="grid"></div>
<script>
const pieces=[
  ["grid_extrude","grid extrude ★","2.5D extruded blocks · stacked param layers","loop / still / scene"],
  ["sdf_raymarch","sdf raymarch","metaball field, smooth booleans, orbit loop","loop / still"],
  ["gyroid","gyroid","TPMS shell SDF · animated phase orbit","loop / still"],
  ["displacement","displacement sphere","noise-displaced sphere · fbm breathing surface","loop / still"],
  ["mandelbulb","mandelbulb","power-8 fractal DE · orbit trap coloring · morph","loop / still"],
  ["fold","fold","kaleidoscopic IFS · menger-style space folding","loop / still"],
  ["flow_field","flow field","noise-advected particles leaving trails","still / loop"],
  ["reaction_diffusion","reaction diffusion","gray-scott organic spots & tendrils","texture / displacement"],
  ["voronoi","voronoi","relaxed cell field, edge↔fill","scaffold / texture"],
  ["contour_field","contour field","marching-squares isolines over noise","still / loop"],
  ["truchet","truchet","flipped arc tiles → flowing curves","tileable texture"],
  ["truchet_b","truchet // color","arc tiles · noise-gradated color field · round cap","still / loop"],
  ["l_system","l-system","stochastic turtle branching","asset / overlay"],
  ["cellular_erosion","cellular erosion","CA-smoothed worn surface depth","displacement + roughness"],
  ["recursive_grid","recursive grid","noise-thresholded quad subdivision","layout / structure"],
];
const g=document.getElementById("grid");
for(const [dir,name,desc,tag] of pieces){
  const a=document.createElement("a");
  a.className="card"; a.href=`../${dir}/noixzy_${dir}.html`;
  a.innerHTML=`<div class="thumb"><img src="thumbs/${dir}.png" alt="${name}"></div>
    <div class="meta"><div class="name">${name}</div>
    <div class="desc">${desc}</div><span class="tag">${tag}</span></div>`;
  g.appendChild(a);
}
</script>
</body>
</html>
